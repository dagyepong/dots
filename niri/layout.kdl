layout {
    gaps 3
    center-focused-column "on-overflow"
    always-center-single-column
    background-color "#151221"

    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    default-column-width { proportion 0.5; }

    preset-window-heights {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    focus-ring {
        off
        width 3
        active-color "#FF5A1F"      // neon orange
        inactive-color "#4e4e6a"
        urgent-color "#ff5555"
        active-gradient from="#FF5A1F" to="#00F5D4" angle=45  // neon orange -> cyan/mint
    }

    border {
        on
        width 3
        active-color "#FF5A1F"      // neon orange
        inactive-color "#4e4e6a"
        urgent-color "#ff5555"
        active-gradient from="#FF5A1F" to="#00F5D4" angle=45
    }

    shadow {
        off
        softness 30
        spread 4
        offset x=0 y=4
        draw-behind-window true
        color "#00000040"
    }

    tab-indicator {
        on
        hide-when-single-tab
        place-within-column
        gap 4
        width 4
        length total-proportion=1.0
        position "left"
        gaps-between-tabs 2
        corner-radius 8
        active-color "#FF5A1F"      // neon orange
        inactive-color "#4e4e6a"
        urgent-color "#ff5555"
        active-gradient from="#FF5A1F" to="#00F5D4" angle=45
    }

    insert-hint {
        on
        color "#FF5A1F80"           // neon orange w/ alpha
    }

    struts {
    }
}

