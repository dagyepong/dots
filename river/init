#!/bin/sh

# This script is designed to replicate the Hyprland configuration for the River window manager.

### MY PROGRAMS ###
TERMINAL="ghostty"
FILE_MANAGER="dolphin -stylesheet ~/archhypr_dotfiles/kde_stuff/dolphin.qss"
MENU="rofi -show drun"

river rule-add ssd
river rule-add -app-id com.mitchellh.ghostty ssd

### AUTOSTART ###
qs -p ~/.config/quickshell/shell.qml &
/usr/libexec/polkit-gnome-authentication-agent-1 &
#exec-once = waybar -c ~/.config/waybar/config.jsonc
swaybg -i /home/nana/Pictures/wallpaper/dopesmoker_gruvbox.png &
kanshi &
swww-daemon &
waybar -c ~/.config/waybar/gruvbox_blocks/config.jsonc -s ~/.config/waybar/gruvbox_blocks/style.css &
dunst &
exec-once = hyprctl setcursor Bibata-Modern-Classic 24
 /usr/lib/polkit-kde-authentication-agent-1 &
wl-paste --type text --watch cliphist store &
wl-paste --type image --watch cliphist store &
hash dbus-update-activation-environment 2>/dev/null &
xdg-desktop-portal-hyprland &
systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP
hyprctl setcursor Bibata-Modern-Classic 24
hyprsunset &

### ENVIRONMENT VARIABLES ###
source "$HOME/.config/river/env.sh"

### LOOK AND FEEL ###
river background-color 0x1d2021
river border-color-focused 0x458588
river border-color-unfocused 0x1d2021
river border-width 3
river view-padding 5
river outer-padding 9
river focus-follows-cursor normal

# Set the default layout to rivertile and start it
river default-layout rivertile
rivertile -main-ratio 0.5 -main-count 1 &
### KEYBINDINGS ###
MOD="Super"

# Launch applications
river map normal $MOD Q spawn $TERMINAL
river map normal $MOD G spawn foot
river map normal $MOD E spawn $FILE_MANAGER
river map normal $MOD R spawn "$MENU"
river map normal $MOD W spawn "firefox"
river map normal $MOD B spawn "rofi-bluetooth"
river map normal $MOD U spawn "rofi -show emoji"
river map normal "$MOD+Shift" K spawn "wine ~/.wine/drive_c/Keil_v5/UV4/UV4.exe"
river map normal "$MOD+Shift" W spawn "sh ~/.config/rofi/rofi-wifi-menu.sh"

# Window management
river map normal $MOD C close
river map normal "$MOD+Shift" M exit
river map normal $MOD V toggle-float
river map normal $MOD J toggle-split
river map normal $MOD L spawn "hyprlock"
river map normal $MOD S spawn "hyprshot -m region -o ~/Pictures/Screenshots/"

# Move focus
river map normal $MOD K focus-view previous
river map normal $MOD J focus-view next

# Switch workspaces (tags in River)
for i in $(seq 1 9); do
    tags=$((1 << ($i - 1)))
    river map normal $MOD $i set-focused-tags $tags
done
river map normal $MOD 0 set-focused-tags $(( (1 << 9) )) # Workspace 10 on tag 9

# Move active window to a workspace
for i in $(seq 1 9); do
    tags=$((1 << ($i - 1)))
    river map normal "$MOD+Shift" $i set-view-tags $tags
done
river map normal "$MOD+Shift" 0 set-view-tags $(( (1 << 9) )) # Workspace 10 on tag 9

# Mouse bindings
river map-pointer normal $MOD BTN_LEFT move-view
river map-pointer normal $MOD BTN_RIGHT resize-view

### Multimedia Keys ###
# Requires playerctl
river map normal None XF86AudioNext spawn "playerctl next"
river map normal None XF86AudioPause spawn "playerctl play-pause"
river map normal None XF86AudioPlay spawn "playerctl play-pause"
river map normal None XF86AudioPrev spawn "playerctl previous"

# Volume and Brightness
river map normal None XF86AudioRaiseVolume spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+"
river map normal None XF86AudioLowerVolume spawn "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
river map normal None XF86AudioMute spawn "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
river map normal None XF86AudioMicMute spawn "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"
river map normal None XF86MonBrightnessUp spawn "brightnessctl set 10%+"
river map normal None XF86MonBrightnessDown spawn "brightnessctl set 10%-"

### WINDOW RULES ###
# Float rules for specific applications
river rule-add -app-id 'waypaper' float
river rule-add -app-id 'nwg-look' float
river rule-add -app-id 'feh' float
