(defpoll brightness :interval "2s"
  "bash /home/nana/.config/eww/scripts/brightness.sh")

(defwidget brightness []
  (box :class "brightness"
       :orientation "h"
       :space-evenly false
    (label :text "󰃠 ")
    (scale :min 1
           :max 100
           :value brightness
           :onchange "brightnessctl set {}%"
           :width 80)))
