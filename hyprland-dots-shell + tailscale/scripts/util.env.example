# scripts/util.env — personal env values. Copy to util.env and fill in.
# Loaded into fish env by fish/conf.d/util-env.fish and into bash by the
# individual scripts that need them (ledvance.sh).

# Ledvance LED pairing (scripts/ledvance.sh)
LEDVANCE_USER=
LEDVANCE_PASSWORD=
LEDVANCE_PATH=

# RPG Maker decrypter (rpgmd fish abbr)
RPGMDECRYPT_PATH=
