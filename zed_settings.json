{
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
      "context_window": 8192
    }
  },
  "colorize_brackets": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "settings": {
        "default_minimum_tokens": "10000"
      }
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "play_sound_when_agent_done": "always",
    "default_profile": "write",
    "default_model": {
      "provider": "ollama",
      "model": "qwen2.5-coder:7b"
    }
  },
  "theme": {
    "mode": "dark",
    "light": "Gruvbox Dark",
    "dark": "Srcery"
  },
  "icon_theme": "Warm Charmed Icons",
  "base_keymap": "SublimeText",
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "buffer_line_height": {
    "custom": 1.4
  },
  "buffer_font_family": "Iosevka Nerd Font Mono",
  "buffer_font_features": {
    "calt": false
  },
  "buffer_font_weight": 300,
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
    "selections_menu": true
  },
  "project_panel": {
    "entry_spacing": "standard"
  },
  "tabs": {
    "file_icons": true
  },
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "format_on_save": "off",
  "hard_tabs": true,
  "tab_size": 4,
  "current_line_highlight": "none"
}
